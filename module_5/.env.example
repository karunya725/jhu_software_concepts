# Replace the username, password, and database name with own local PostgreSQL setup.
# If your password contains special characters, URL-encode them.
# Example: @ becomes %40

DB_HOST=localhost
DB_PORT=5432
DB_NAME=gradcafe_db
DB_USER=gradcafe_app_user
DB_PASSWORD=replace_with_password

DATABASE_URL=postgresql://gradcafe_app_user:replace_with_password@localhost:5432/gradcafe_db

# Test database used by pytest
# Use this DATABASE_URL instead when running the test suite locally:
# DATABASE_URL=postgresql://postgres:replace_with_password@localhost:5432/gradcafe_test_db

# Flask debug mode should be false by default for security.
FLASK_DEBUG=false